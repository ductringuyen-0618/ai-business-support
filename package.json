{
  "name": "ai-business-support",
  "version": "0.1.0",
  "private": true,
  "description": "Self-serve B2B SaaS that aggregates Reviews for a Business from external Sources, classifies them into Themes / Incidents, escalates to Operators, and ships a weekly Digest.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/worker/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.12.0",
    "@neondatabase/serverless": "^0.10.4",
    "date-fns": "^4.3.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.38.3",
    "next": "15.5.4",
    "pg-boss": "^10.1.6",
    "postgres": "^3.4.5",
    "react": "^19.0.3",
    "react-dom": "^19.0.3",
    "svix": "^1.94.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.4",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7"
  }
}
