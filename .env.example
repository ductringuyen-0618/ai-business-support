# ---------------------------------------------------------------------------
# ai-business-support — example environment variables
#
# Copy this file to `.env.local` for local development and fill in real values.
# Every entry below is needed for the full MVP (per the PRD); Slice 1 itself
# only strictly requires DATABASE_URL + CLERK_* + APP_BASE_URL to boot.
# ---------------------------------------------------------------------------

# --- App ----------------------------------------------------------------
# Public base URL of the deployed app; used to build callback links etc.
# Local dev: http://localhost:3000. Production: https://app.example.com.
APP_BASE_URL=http://localhost:3000

# --- Database (Neon Postgres) -------------------------------------------
# Pooled URL used by the Next.js runtime (HTTP-pooled via @neondatabase/serverless).
# Get it from Neon console → Connection Details → "Pooled connection".
DATABASE_URL=postgresql://user:password@ep-xxxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Unpooled (direct) URL used by long-lived connections: pg-boss worker and
# `pnpm db:migrate`. Get it from Neon console → Connection Details and
# UNTICK "Pooled connection".
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxxxx.region.aws.neon.tech/dbname?sslmode=require

# --- Auth (Clerk) -------------------------------------------------------
# From the Clerk dashboard → API Keys.
# https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Webhook signing secret from Clerk dashboard → Webhooks → endpoint detail.
# Used to verify Clerk → app webhook payloads in a later slice.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# Where Clerk's hosted components should redirect to. Leave as defaults
# unless you change the route layout in `src/app`.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app/dashboard

# --- LLM (Anthropic) ----------------------------------------------------
# From https://console.anthropic.com/ → API Keys.
# Used by the Classifier and DigestComposer (later slices).
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Source: Google Business Profile -----------------------------------
# OAuth client for the Google Business Profile read-only scope (slice 8).
# See README.md "Google Cloud setup" for the runbook.
# https://console.cloud.google.com/ → APIs & Services → Credentials.
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx

# Shared secret used to verify Google Pub/Sub push messages for new Reviews.
# Generate any random opaque string; configure the same value in Pub/Sub.
GOOGLE_PUBSUB_VERIFICATION_TOKEN=changeme

# --- Source token encryption (slice 8) ----------------------------------
# 32 bytes of entropy, base64-encoded. Used to encrypt every
# `source_connections.oauth_*_token` value at rest with AES-256-GCM. Rotate by
# generating a fresh value; the codebase carries `v1:` ciphertexts so a future
# rotation can ship `v2:` alongside without a DB migration.
#
# Generate with:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
SOURCE_TOKEN_ENCRYPTION_KEY=replace-with-32-random-bytes-base64-encoded

# --- Email (Resend) -----------------------------------------------------
# From https://resend.com/ → API Keys. Used to send Escalations and Digests.
RESEND_API_KEY=re_xxx

# --- SMS (Twilio) -------------------------------------------------------
# From the Twilio console → Account Info / Phone Numbers.
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+15555550123
